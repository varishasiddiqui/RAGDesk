# ---- RAGDesk Environment Variables ----
# Copy this file to ".env.local" and fill in your values.
# On Vercel, add these in Project Settings → Environment Variables.

# Required — Google Gemini API key
# Used for BOTH embeddings (gemini-embedding-001) and LLM answers (gemini-2.5-flash).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ---- Optional (for local development only) ----
# The app uses an in-memory vector store by default (no setup needed).
# Data persists while the serverless function stays warm.
# On cold starts, you simply re-upload your PDF — perfect for a portfolio demo.
